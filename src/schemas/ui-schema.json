{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UISchema",
  "type": "object",
  "required": ["pages", "navigation", "theme"],
  "properties": {
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "path", "components", "authRequired"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "path": { "type": "string", "pattern": "^/" },
          "title": { "type": "string" },
          "authRequired": { "type": "boolean" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "layout": { "type": "string", "enum": ["default", "sidebar", "fullscreen", "centered"] },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string", "enum": ["form", "table", "chart", "card", "text", "button", "nav", "hero", "stats", "modal"] },
                "props": { "type": "object" },
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "label": { "type": "string" },
                      "type": { "type": "string", "enum": ["text", "email", "password", "number", "select", "textarea", "date", "checkbox", "file"] },
                      "required": { "type": "boolean" },
                      "options": { "type": "array", "items": { "type": "string" } },
                      "apiField": { "type": "string" }
                    }
                  }
                },
                "action": { "type": "string" },
                "columns": { "type": "array", "items": { "type": "string" } },
                "dataSource": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "navigation": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "type": { "type": "string", "enum": ["sidebar", "topbar", "both"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "path"],
            "properties": {
              "label": { "type": "string" },
              "path": { "type": "string" },
              "icon": { "type": "string" },
              "roles": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "theme": {
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "mode": { "type": "string", "enum": ["light", "dark"] }
      }
    }
  }
}
