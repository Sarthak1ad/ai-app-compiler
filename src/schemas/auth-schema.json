{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuthSchema",
  "type": "object",
  "required": ["roles", "permissions", "guards"],
  "properties": {
    "strategy": { "type": "string", "enum": ["jwt", "session", "oauth"] },
    "tokenExpiry": { "type": "string" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "isDefault": { "type": "boolean" },
          "inherits": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "resource", "actions"],
        "properties": {
          "role": { "type": "string" },
          "resource": { "type": "string" },
          "actions": {
            "type": "array",
            "items": { "type": "string", "enum": ["create", "read", "update", "delete", "manage"] }
          },
          "conditions": { "type": "string" }
        }
      }
    },
    "guards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "roles"],
        "properties": {
          "path": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "redirect": { "type": "string" }
        }
      }
    },
    "loginPage": { "type": "string" },
    "registerPage": { "type": "string" }
  }
}
